# ==========================================================================
# ZenMotion backend — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ==========================================================================

# ---- Server ----
NODE_ENV=development
PORT=4000
# Public base URL of THIS api (used to build webhook & return URLs)
API_BASE_URL=http://localhost:4000
# Public base URL of the FRONTEND (used for CORS + checkout success/cancel redirects)
FRONTEND_BASE_URL=http://localhost:5173
# Comma-separated list of additional allowed CORS origins (optional)
CORS_EXTRA_ORIGINS=

# ---- Database ----
# Path to the SQLite database file (relative to project root)
DATABASE_FILE=data/zenmotion.db

# ---- Auth / JWT ----
# Generate strong secrets, e.g.  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Store / pricing ----
CURRENCY=USD
# Flat shipping fee in MINOR units (cents) applied when cart has a physical item
SHIPPING_FLAT_CENTS=900
# Free shipping threshold in MINOR units (0 = disabled)
FREE_SHIPPING_THRESHOLD_CENTS=0
# Statement descriptor shown on the customer's card statement
STATEMENT_DESCRIPTOR=ZENMOTION

# ---- Airwallex ----
# Get these from the Airwallex dashboard. Use the demo/sandbox keys while testing.
# Base: https://api-demo.airwallex.com (sandbox) or https://api.airwallex.com (live)
AIRWALLEX_BASE_URL=https://api-demo.airwallex.com
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
# Webhook signing secret from the Airwallex dashboard webhook settings
AIRWALLEX_WEBHOOK_SECRET=
# Which integration to use for /api/checkout: "hosted" (Hosted Payment Page) or "intent" (Payment Intent + client secret)
AIRWALLEX_MODE=hosted

# ---- Email (Nodemailer SMTP) ----
# If SMTP_HOST is empty, emails are logged to the console instead of being sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="ZenMotion <support@zenmotionpeace.com>"
SUPPORT_EMAIL=support@zenmotionpeace.com
